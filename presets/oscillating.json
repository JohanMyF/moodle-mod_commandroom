{
  "metadata": {
    "plugin": "mod_commandroom",
    "pluginname": "Situation Room",
    "version": "oscillation-archetype-test",
    "timesteplabel": "week",
    "stepduration": 1,
    "stepdurationunit": "week",
    "totaliterations": 104,
    "useshocks": true
  },
  "nodes": [
    {
      "ref": "public_interest",
      "name": "Public Interest",
      "description": "The level of current interest in the course/campaign/community topic. This is the main stock that rises and falls over time.",
      "unitlabel": "interest points",
      "interpretation": "Public Interest = prior Public Interest + Net Interest Pressure - Interest Fade.",
      "nodetype": "stock",
      "initialvalue": 50,
      "minvalue": 0,
      "maxvalue": 120,
      "studentcontrolled": false,
      "visibletostudents": true,
      "displayorder": 1,
      "visual": {
        "type": "scaling_icon",
        "icon": "default",
        "minvalue": 0,
        "maxvalue": 120,
        "minsize": 60,
        "maxsize": 180,
        "x": 7,
        "y": 5,
        "w": 3,
        "h": 3
      },
      "updateconfig": {
        "mode": "stock_with_rate",
        "base": "self",
        "inflows": [
          "net_interest_pressure"
        ],
        "outflows": [
          "interest_fade"
        ],
        "adds": [
          "net_interest_pressure"
        ],
        "subtracts": [
          "interest_fade"
        ]
      }
    },
    {
      "ref": "seasonal_push",
      "name": "Seasonal Push",
      "description": "A repeating outside force that rises and falls over a 26-week cycle. It represents seasonal attention, events, media interest, or campaign timing.",
      "unitlabel": "pressure points",
      "interpretation": "This starter archetype uses scheduled shocks to create a visible oscillation.",
      "nodetype": "stock",
      "initialvalue": 0,
      "minvalue": -12,
      "maxvalue": 12,
      "studentcontrolled": false,
      "visibletostudents": true,
      "displayorder": 2,
      "visual": {
        "type": "scaling_icon",
        "icon": "default",
        "minvalue": -12,
        "maxvalue": 12,
        "minsize": 50,
        "maxsize": 140,
        "x": 2,
        "y": 2,
        "w": 3,
        "h": 3
      }
    },
    {
      "ref": "baseline_pull",
      "name": "Baseline Pull",
      "description": "A small constant amount of background interest that prevents the system from staying flat at zero.",
      "unitlabel": "points/week",
      "nodetype": "variable",
      "initialvalue": 3,
      "minvalue": 0,
      "maxvalue": 20,
      "studentcontrolled": false,
      "visibletostudents": true,
      "displayorder": 3,
      "visual": {
        "type": "scaling_icon",
        "icon": "default",
        "minvalue": 0,
        "maxvalue": 20,
        "minsize": 50,
        "maxsize": 140,
        "x": 2,
        "y": 7,
        "w": 3,
        "h": 3
      }
    },
    {
      "ref": "net_interest_pressure",
      "name": "Net Interest Pressure",
      "description": "The weekly pressure pushing interest upward or downward before ordinary fading is deducted.",
      "unitlabel": "points/week",
      "interpretation": "Net Interest Pressure = Baseline Pull + Seasonal Push.",
      "nodetype": "computed",
      "initialvalue": 3,
      "minvalue": -15,
      "maxvalue": 15,
      "studentcontrolled": false,
      "visibletostudents": true,
      "displayorder": 4,
      "visual": {
        "type": "scaling_icon",
        "icon": "default",
        "minvalue": -15,
        "maxvalue": 15,
        "minsize": 50,
        "maxsize": 140,
        "x": 7,
        "y": 2,
        "w": 3,
        "h": 3
      },
      "calculation": {
        "type": "sum",
        "items": [
          {
            "factor": 1,
            "operand": {
              "kind": "node",
              "ref": "baseline_pull"
            }
          },
          {
            "factor": 1,
            "operand": {
              "kind": "node",
              "ref": "seasonal_push"
            }
          }
        ]
      }
    },
    {
      "ref": "fade_rate",
      "name": "Fade Rate",
      "description": "The proportion of current interest that fades each week.",
      "unitlabel": "decimal rate",
      "nodetype": "variable",
      "initialvalue": 0.08,
      "minvalue": 0,
      "maxvalue": 0.3,
      "studentcontrolled": false,
      "visibletostudents": true,
      "displayorder": 5,
      "visual": {
        "type": "scaling_icon",
        "icon": "default",
        "minvalue": 0,
        "maxvalue": 0.3,
        "minsize": 50,
        "maxsize": 140,
        "x": 12,
        "y": 7,
        "w": 3,
        "h": 3
      }
    },
    {
      "ref": "interest_fade",
      "name": "Interest Fade",
      "description": "The weekly loss of interest caused by attention decay.",
      "unitlabel": "points/week",
      "interpretation": "Interest Fade = Public Interest \u00d7 Fade Rate.",
      "nodetype": "computed",
      "initialvalue": 4,
      "minvalue": 0,
      "maxvalue": 30,
      "studentcontrolled": false,
      "visibletostudents": true,
      "displayorder": 6,
      "visual": {
        "type": "scaling_icon",
        "icon": "default",
        "minvalue": 0,
        "maxvalue": 30,
        "minsize": 50,
        "maxsize": 140,
        "x": 12,
        "y": 2,
        "w": 3,
        "h": 3
      },
      "calculation": {
        "type": "multiply",
        "left": {
          "kind": "node",
          "ref": "public_interest"
        },
        "right": {
          "kind": "node",
          "ref": "fade_rate"
        }
      }
    }
  ],
