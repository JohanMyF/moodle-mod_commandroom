{
  "metadata": {
    "plugin": "mod_commandroom",
    "pluginname": "Situation Room",
    "version": "first-release-archetype",
    "archetype": "backlog_reduction",
    "timesteplabel": "day",
    "stepduration": 1,
    "stepdurationunit": "day",
    "totaliterations": 30,
    "useshocks": false
  },
  "nodes": [
    {
      "ref": "patient_backlog",
      "name": "Patient Backlog",
      "description": "Patients waiting to be processed by the clinic.",
      "unitlabel": "patients",
      "interpretation": "Backlog increases with arrivals and decreases when patients are processed.",
      "nodetype": "stock",
      "initialvalue": 80,
      "minvalue": 0,
      "maxvalue": 500,
      "studentcontrolled": false,
      "visibletostudents": true,
      "displayorder": 1,
      "visual": {
        "type": "scaling_icon",
        "icon": "default",
        "minvalue": 0,
        "maxvalue": 100,
        "minsize": 50,
        "maxsize": 150,
        "x": 6,
        "y": 5,
        "w": 4,
        "h": 3
      },
      "updateconfig": {
        "mode": "stock_with_rate",
        "base": "self",
        "inflows": [
          "patient_arrivals"
        ],
        "outflows": [
          "patients_processed"
        ],
        "adds": [
          "patient_arrivals"
        ],
        "subtracts": [
          "patients_processed"
        ]
      }
    },
    {
      "ref": "patient_arrivals",
      "name": "Patient Arrivals",
